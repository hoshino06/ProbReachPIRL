import json
from pathlib import Path
files = [
 'scheduling_experiment/fixed2randT_replayHJB_7Mto10M_restart2/round_000/results.json',
 'scheduling_experiment/fixed2randT_replayHJB_5Mto10M_restart/all_results.json',
 'scheduling_experiment/fixed2randT_replayHJB_5Mto10M/all_results.json',
]
for f in files:
    p=Path(f)
    print('\\n##', f)
    data=json.loads(p.read_text())
    if isinstance(data, dict):
        data=data.get('results') or data.get('candidates') or [data]
    for r in data:
        cand=r.get('candidate', r)
        m=r.get('mc_metrics', {})
        tb=r.get('tensorboard_last', {})
        def g(plane, key):
            return m.get(plane,{}).get(key)
        print({
            'name': r.get('name') or cand.get('name'),
            'start': cand.get('start_checkpoint'),
            'ckpt': r.get('checkpoint'),
            'target': r.get('target_updates'),
            'init': cand.get('schedule_initial'),
            'final': cand.get('schedule_final'),
            'reward': tb.get('RL/Average Reward'),
            'br_mc': g('beta_r','mean_mc'),
            'br_err': g('beta_r','mean_abs_mc_v'),
            'ee_mc': g('ey_epsi','mean_mc'),
            'ee_err': g('ey_epsi','mean_abs_mc_v'),
        })
