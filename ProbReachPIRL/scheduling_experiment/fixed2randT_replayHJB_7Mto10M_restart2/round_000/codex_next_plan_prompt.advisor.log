  fi

  if [[ -n "${SCHEDULE_SHARPNESS}" ]]; then
    CMD+=(--schedule_sharpness "${SCHEDULE_SHARPNESS}")
  fi

  if [[ -n "${SCHEDULE_INITIAL}" ]]; then
    read -r -a INITIAL_WEIGHTS <<< "${SCHEDULE_INITIAL}"
    CMD+=(--schedule_initial "${INITIAL_WEIGHTS[@]}")
